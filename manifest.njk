---
permalink: /manifest.webmanifest
eleventyExcludeFromCollections: true
---
{
  "name": {{ site.name | dump | safe }},
  "short_name": {{ site.shortName | dump | safe }},
  "description": {{ site.description | dump | safe }},
  "lang": "{{ site.lang }}",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
  "background_color": "{{ site.backgroundColor }}",
  "theme_color": "{{ site.themeColor }}",
  "categories": ["productivity", "reference", "developer"],
  "icons": [
    { "src": "/assets/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/assets/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/assets/icons/maskable-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" },
    { "src": "/assets/icons/favicon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" }
  ]
}
